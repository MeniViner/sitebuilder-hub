SERVER_PORT=4100
MONGO_URI=mongodb://127.0.0.1:27017/sitebuilder_hub

# Browser origins allowed to call the API.
# Local dev only:
CLIENT_ORIGIN=http://localhost:5177
# SharePoint-hosted owner mode can use:
# CLIENT_ORIGIN=https://portal.army.idf
# Multiple origins are supported without code changes.
CLIENT_ORIGINS=https://portal.army.idf,http://localhost:5177,http://127.0.0.1:5177

# AUTH_ENABLED=false is owner-direct/dev mode. In SharePoint hosting the browser
# current user is detected via /_api/web/currentuser and forwarded to the API.
# True localhost falls back to a visible local development identity.
AUTH_ENABLED=false
API_KEY=dev-local-key
HUB_OWNER_PERSONAL_NUMBER=s8856096
BOOTSTRAP_ADMIN_PERSONAL_NUMBERS=s8856096

# Default MVP mode: no approval friction for the owner.
HUB_OWNER_DIRECT_MODE=true
HUB_ADVANCED_APPROVALS_ENABLED=false

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
JOB_WORKER_ENABLED=true
JOB_WORKER_POLL_MS=3000
JOB_APPROVAL_TTL_HOURS=24
MAINTENANCE_SCHEDULER_ENABLED=true
MAINTENANCE_SCHEDULER_POLL_MS=60000
MAINTENANCE_SCHEDULER_MAX_SITES_PER_TICK=25
MONITORING_STALE_BACKUP_HOURS=26

# Builder/Mongo backend connector for Mongo-backed Site Builder sites.
# SITE_BUILDER_BACKEND_API_URLS is an allowlist shown in Settings/Diagnostics.
# SITE_BUILDER_DEFAULT_API_KEY_REF names an env var; do not store raw API keys in site records.
SITE_BUILDER_BACKEND_API_URLS=http://127.0.0.1:3001
SITE_BUILDER_DEFAULT_BACKEND_API_URL=http://127.0.0.1:3001
SITE_BUILDER_DEFAULT_BACKEND_LABEL=Local Builder Backend
SITE_BUILDER_DEFAULT_API_KEY_REF=SITE_BUILDER_BACKEND_API_KEY
SITE_BUILDER_BACKEND_DEFAULT_API_KEY_REF=SITE_BUILDER_BACKEND_API_KEY
SITE_BUILDER_DEFAULT_STORAGE_BACKEND=unknown
HUB_ADVANCED_MANUAL_SITE_FIELDS_ENABLED=true
SITE_BUILDER_BACKEND_API_KEY=
SHAREPOINT_WRITE_ENABLED=false
SHAREPOINT_ALLOW_UNAUTHENTICATED_WRITE=false
SHAREPOINT_AUTH_COOKIE=
SHAREPOINT_BEARER_TOKEN=
SHAREPOINT_REQUEST_TIMEOUT_MS=15000
SHAREPOINT_SITE_CREATE_POLL_ATTEMPTS=24
SHAREPOINT_SITE_CREATE_POLL_INTERVAL_MS=5000
HUB_LOCAL_DEV_DEPLOY_REQUIRES_BACKUP=false
HUB_PRODUCTION_DEPLOY_REQUIRES_BACKUP=false
HUB_PRODUCTION_DEPLOY_REQUIRES_APPROVAL=false

# Dangerous owner overrides. Keep false unless you intentionally want to bypass
# recent verified backup gates for emergency/local owner operations.
HUB_DANGEROUS_ALLOW_DEPLOY_WITHOUT_BACKUP=false
HUB_DANGEROUS_ALLOW_ROLLBACK_WITHOUT_BACKUP=false
HUB_DANGEROUS_ALLOW_RESTORE_WITHOUT_BACKUP=false

# Nuclear switch: bypass every Hub validation gate listed below.
# Real SharePoint/browser HTTP calls can still fail; this does not fake writes.
HUB_DANGEROUS_BYPASS_ALL_VALIDATION_GATES=false

# Focused dangerous validation bypasses.
HUB_DANGEROUS_BYPASS_APPROVAL_GATES=false
HUB_DANGEROUS_BYPASS_SHAREPOINT_WRITE_GATES=false
HUB_DANGEROUS_BYPASS_RELEASE_ARTIFACT_VALIDATION=false
HUB_DANGEROUS_BYPASS_DEPLOY_PLAN_BLOCKERS=false
HUB_DANGEROUS_BYPASS_RESTORE_EVIDENCE_GATES=false
HUB_DANGEROUS_BYPASS_BROWSER_EVIDENCE_GATES=false
HUB_DANGEROUS_BYPASS_ADMIN_REPAIR_GATES=false

# SharePoint modes:
# 1. Local dev only: SHAREPOINT_WRITE_ENABLED=false.
# 2. SharePoint-hosted read-only: keep write disabled; browser current-user and read diagnostics still work.
# 3. SharePoint write/deploy: set SHAREPOINT_WRITE_ENABLED=true and configure either
#    SHAREPOINT_AUTH_COOKIE or SHAREPOINT_BEARER_TOKEN. Then verify /api/diagnostics/sharepoint-check.
# Warning: SHAREPOINT_ALLOW_UNAUTHENTICATED_WRITE=true only allows the backend to attempt writes;
# it does not mean SharePoint will accept writes. Digest/contextinfo must succeed.

APP_VERSION=0.1.20

# Console logging sections. Flip any category true/false as needed.
LOG_ALL=false
LOG_FORMAT=pretty
LOG_VERBOSE_PAYLOADS=false
LOG_HTTP_PAYLOADS=false
LOG_SHOW_SENSITIVE=false
LOG_SERVER=true
LOG_ENV=false
LOG_HTTP=true
LOG_AUTH=true
LOG_RATE_LIMIT=false
LOG_DB=false
LOG_JOBS=true
LOG_AUDIT=true
LOG_SITES=true
LOG_RELEASES=true
LOG_BACKUPS=true
LOG_MONITORING=true
LOG_ADMINS=true
LOG_OPERATIONS=true
LOG_SHAREPOINT=true
LOG_SECURITY=true
LOG_ERRORS=true
LOG_PERFORMANCE=false

# Browser/client logging categories.
VITE_LOG_ALL=false
VITE_LOG_FORMAT=pretty
VITE_LOG_APP=true
VITE_LOG_API=true
VITE_LOG_AUDIT=true
VITE_LOG_MONITORING=true
VITE_LOG_AUTH=true
VITE_LOG_ROUTER=false
VITE_LOG_UI=false
VITE_LOG_STATE=false
VITE_LOG_STORAGE=false
VITE_LOG_BROWSER_FETCH=false
VITE_LOG_ERRORS=true
VITE_LOG_PERFORMANCE=false

# Hebrew contextual help icons are enabled by default. Set to false to hide
# inline question/info icons while keeping /help available.
VITE_HUB_HELP_ICONS_ENABLED=true
