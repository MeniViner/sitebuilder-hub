VITE_API_BASE_URL=http://localhost:4100/api

# Client console logging sections. Flip any category true/false as needed.
VITE_LOG_ALL=false
VITE_LOG_FORMAT=pretty
VITE_LOG_VERBOSE_PAYLOADS=false
VITE_LOG_API_PAYLOADS=false
VITE_LOG_SHOW_SENSITIVE=false
VITE_LOG_APP=true
VITE_LOG_API=true
VITE_LOG_AUTH=true
VITE_LOG_ROUTER=true
VITE_LOG_UI=false
VITE_LOG_STATE=false
VITE_LOG_STORAGE=false
VITE_LOG_BROWSER_FETCH=false
VITE_LOG_PERFORMANCE=false
VITE_LOG_ERRORS=true
